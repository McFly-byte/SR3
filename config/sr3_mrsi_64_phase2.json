{
    "name": "sr3_mrsi_64_phase2",
    "phase": "train",
    "gpu_ids": [
        0,
        1,
        2
    ],
    "path": {
        "log": "logs",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
    },
    "datasets": {
        "train": {
            "name": "MRSI_train",
            "mode": "MRSI_SR3",
            "dataroot": "dataset_mrsi/mrsi_sr3_64/train",
            "datatype": "npz",
            "l_resolution": 64,
            "r_resolution": 64,
            "batch_size": 48,
            "num_workers": 8,
            "use_shuffle": true,
            "data_len": -1,
            "hflip": true,
            "vflip": false
        },
        "val": {
            "name": "MRSI_val",
            "mode": "MRSI_SR3",
            "dataroot": "dataset_mrsi/mrsi_sr3_64/val",
            "datatype": "npz",
            "l_resolution": 64,
            "r_resolution": 64,
            "data_len": -1,
            "hflip": false,
            "vflip": false
        }
    },
    "model": {
        "which_model_G": "sr3",
        "finetune_norm": false,
        "unet": {
            "in_channel": 8,           // 7 cond channels + 1 noisy target
            "out_channel": 1,          // single-channel metabolite
            "inner_channel": 64,
            "channel_multiplier": [
                1,
                2,
                4,
                8
            ],
            "attn_res": [
                16,
                32
            ],
            "res_blocks": 2,
            "dropout": 0.1,
            // T1 Cross-Attention: set t1_in_channel=1 to enable the T1Encoder + CrossAttentionBlock.
            // t1_channel_idx (in diffusion section) must point to the T1 channel in the 7-ch condition.
            // Condition layout: [lr(0), t1(1), flair(2), met_onehot(3,4,5,6)]
            "t1_in_channel": 1,
            "t1_cross_attn_res": [16, 32]  // apply cross-attn at these decoder resolutions
        },
        "beta_schedule": {
            "train": {
                "schedule": "cosine",
                "n_timestep": 1000,
                "linear_start": 1e-6,
                "linear_end": 1e-2
            },
            "val": {
                "schedule": "cosine",
                "n_timestep": 1000,
                "linear_start": 1e-6,
                "linear_end": 1e-2
            }
        },
        "diffusion": {
            "image_size": 64,
            "channels": 1,
            "conditional": true,
            "sampler_type": "ddim",
            "sample_num_steps": 50,
            "mask_loss_weight": 2.0,
            "freq_loss_weight": 0.1,    // FFT-L1 auxiliary loss weight (Phase 2 feature)
            "t1_channel_idx": 1         // index of T1 within the 7-channel condition tensor
        }
    },
    "metrics": {
        "enable_lpips": true,
        "lpips_net": "alex",
        "enable_frc": true,
        "frc_apodize": true
    },
    "train": {
        "n_iter": 300000,
        "val_freq": 2000,
        "save_checkpoint_freq": 5000,
        "print_freq": 100,
        "val_max_samples": -1,
        "optimizer": {
            "type": "adam",
            "lr": 1e-4
        },
        "ema_scheduler": {
            "step_start_ema": 5000,
            "update_ema_every": 1,
            "ema_decay": 0.9999
        }
    },
    "wandb": {
        "project": "sr3_mrsi"
    }
}
